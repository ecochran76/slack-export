{
  "_metadata": {
    "major_version": 1,
    "minor_version": 1
  },
  "display_information": {
    "name": "${SLACK_MIRROR_APP_NAME:-Slack Mirror Socket}",
    "description": "${SLACK_MIRROR_APP_DESCRIPTION:-Dedicated Slack Mirror app using Socket Mode}",
    "background_color": "#1D9BF0"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": false,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": true
    },
    "bot_user": {
      "display_name": "${SLACK_MIRROR_BOT_DISPLAY_NAME:-Slack Mirror}",
      "always_online": false
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "${SLACK_MIRROR_REDIRECT_URL:-https://localhost:3000/slack/oauth/callback}"
    ],
    "scopes": {
      "bot": [
        "app_mentions:read",
        "channels:history",
        "channels:read",
        "channels:write",
        "chat:write",
        "files:read",
        "groups:history",
        "groups:read",
        "groups:write",
        "im:history",
        "im:read",
        "im:write",
        "mpim:history",
        "mpim:read",
        "mpim:write",
        "users:read"
      ],
      "user": [
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "im:read",
        "mpim:history",
        "mpim:read",
        "users:read"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im",
        "message.mpim"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
